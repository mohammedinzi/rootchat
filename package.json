{
  "name": "rootchat",
  "version": "1.0.0",
  "description": "A hacker-movie themed real-time terminal chatroom you can self-host in one command.",
  "main": "server/index.js",
  "bin": {
    "rootchat": "./bin/rootchat.js"
  },
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "chat": "node bin/rootchat.js",
    "share": "node bin/share.js"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "express": "^4.19.2",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5"
  }
}
